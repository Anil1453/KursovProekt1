@model IEnumerable<ControlPanel.Models.AccessLog>
@{
    ViewData["Title"] = "Логове";
}

<h1>Логове за достъп</h1>

@* Филтър по статус *@
<form method="get" class="mb-3">
    <div class="row">
        <div class="col-md-3">
            <select name="status" class="form-control">
                <option value="">-- Всички --</option>
                <option value="Approved" selected="@(ViewBag.SelectedStatus == "Approved")">Одобрен</option>
                <option value="Denied" selected="@(ViewBag.SelectedStatus == "Denied")">Отказан</option>
            </select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary">Филтрирай</button>
        </div>
    </div>
</form>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Потребител</th>
            <th>Стая</th>
            <th>Време</th>
            <th>Статус</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var log in Model)
        {
            <tr>
                <td>@log.User?.Email</td>
                <td>@log.Room?.RoomName</td>
                <td>@log.EntryTime.ToString("dd.MM.yyyy HH:mm")</td>
                <td>
                    @if (log.Status == "Approved")
                    {
                        <span class="badge bg-success">Одобрен</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Отказан</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>