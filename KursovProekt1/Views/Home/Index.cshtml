@{
    ViewData["Title"] = "Начало";
}

<div class="text-center">
    <h1 class="display-4">Система за контрол на достъпа</h1>
    <p>Добре дошли в административния панел</p>
</div>

<div class="row mt-5">
    <div class="col-md-4">
        <div class="card text-white bg-primary mb-3">
            <div class="card-body">
                <h5 class="card-title">Стаи</h5>
                <p class="card-text display-4">@ViewBag.TotalRooms</p>
                <a href="/Room/Index" class="btn btn-light">Преглед</a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card text-white bg-success mb-3">
            <div class="card-body">
                <h5 class="card-title">Потребители</h5>
                <p class="card-text display-4">@ViewBag.TotalUsers</p>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card text-white bg-info mb-3">
            <div class="card-body">
                <h5 class="card-title">Логове</h5>
                <p class="card-text display-4">@ViewBag.TotalLogs</p>
                <a href="/AccessLog/Index" class="btn btn-light">Преглед</a>
            </div>
        </div>
    </div>
</div>