@model ControlPanel.Models.Room

@{
    ViewData["Title"] = "Детайли за зона";
}

<div class="cp-page-header">
    <div>
        <div class="cp-page-title">@Model.RoomName</div>
        <div class="cp-page-subtitle">Детайли и потребители с достъп</div>
    </div>
    <div style="display:flex;gap:8px">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="cp-btn cp-btn-ghost">
            <svg fill="currentColor" viewBox="0 0 20 20"><path d="M13.586 3.586a2 2 0 1 1 2.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z"/></svg>
            Редактирай
        </a>
        <a asp-action="Index" class="cp-btn cp-btn-ghost">← Назад</a>
    </div>
</div>

<div class="cp-grid-2">
    <div class="cp-card">
        <div class="cp-card-header">
            <span class="cp-card-title">Информация за зоната</span>
            @if (Model.IsActive)
            { <span class="cp-badge cp-badge-green"><span class="dot"></span> Активна</span> }
            else
            { <span class="cp-badge cp-badge-gray"><span class="dot"></span> Неактивна</span> }
        </div>
        <div class="cp-card-body">
            <div style="display:flex;flex-direction:column;gap:14px">
                <div style="display:flex;justify-content:space-between;padding-bottom:12px;border-bottom:1px solid var(--border)">
                    <span style="font-size:13px;color:var(--muted)">Име на зоната</span>
                    <span style="font-size:14px;font-weight:600">@Model.RoomName</span>
                </div>
                <div style="display:flex;justify-content:space-between;padding-bottom:12px;border-bottom:1px solid var(--border)">
                    <span style="font-size:13px;color:var(--muted)">Код</span>
                    <span style="font-family:monospace;font-size:13px;background:#f3f4f6;padding:2px 8px;border-radius:4px">@Model.RoomCode</span>
                </div>
                <div style="display:flex;justify-content:space-between;padding-bottom:12px;border-bottom:1px solid var(--border)">
                    <span style="font-size:13px;color:var(--muted)">Ниво на достъп</span>
                    <span class="cp-level cp-level-@Model.AccessLevel">
                        @switch (Model.AccessLevel)
                        {
                            case 1: <text>Ниво 1 — Всички</text> break;
                            case 2: <text>Ниво 2 — Служители</text> break;
                            case 3: <text>Ниво 3 — Мениджъри</text> break;
                            case 4: <text>Ниво 4 — Администратор</text> break;
                        }
                    </span>
                </div>
                <div style="display:flex;justify-content:space-between">
                    <span style="font-size:13px;color:var(--muted)">Описание</span>
                    <span style="font-size:14px;color:var(--text);text-align:right;max-width:60%">@(string.IsNullOrEmpty(Model.Description) ? "—" : Model.Description)</span>
                </div>
            </div>
        </div>
    </div>

    <div class="cp-card">
        <div class="cp-card-header">
            <span class="cp-card-title">Потребители с достъп</span>
            <span style="font-size:12px;color:var(--muted)">@((ViewBag.UsersWithAccess as IEnumerable<dynamic>)?.Count() ?? 0) потребителя</span>
        </div>
        <div class="cp-card-body-flush">
            @{
                var users = ViewBag.UsersWithAccess as IEnumerable<dynamic>;
            }
            @if (users != null && users.Any())
            {
                <table class="cp-table">
                    <thead>
                        <tr>
                            <th>Потребител</th>
                            <th>Одобрено на</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var req in users)
                        {
                            <tr>
                                <td>
                                    <div style="display:flex;align-items:center;gap:8px">
                                        <div class="cp-avatar green">@((req.User?.Email ?? "??").Substring(0,2).ToUpper())</div>
                                        <span style="font-size:13px;font-weight:500">@(req.User?.Email ?? "—")</span>
                                    </div>
                                </td>
                                <td style="font-size:12px;color:var(--muted)">
                                    @(req.ApprovalDate != null ? ((DateTime)req.ApprovalDate).ToString("dd.MM.yyyy HH:mm") : "—")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="cp-empty">
                    <div class="cp-empty-icon">
                        <svg fill="currentColor" viewBox="0 0 20 20"><path d="M9 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0zM17 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 0 0-1.5-4.33A5 5 0 0 1 19 16v1h-6.07zM6 11a5 5 0 0 1 5 5v1H1v-1a5 5 0 0 1 5-5z"/></svg>
                    </div>
                    <div class="cp-empty-title">Няма потребители</div>
                    <div class="cp-empty-sub">Все още никой няма одобрен достъп до тази зона.</div>
                </div>
            }
        </div>
    </div>
</div>
