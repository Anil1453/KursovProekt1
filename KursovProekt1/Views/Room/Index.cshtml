@model IEnumerable<ControlPanel.Models.Room>

@{
    ViewData["Title"] = "Списък със стаи";
}

<h1>Списък със стаи</h1>

<p>
    <a asp-action="Create" class="btn btn-success">➕ Добави нова стая</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Име на стаята</th>
            <th>Код</th>
            <th>Ниво на достъп</th>
            <th>Активна</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any())
        {
            @foreach (var room in Model)
            {
                <tr>
                    <td>@room.RoomName</td>
                    <td>@room.RoomCode</td>
                    <td>@room.AccessLevel</td>
                    <td>
                        @if (room.IsActive)
                        {
                            <span class="badge bg-success">Да</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Не</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@room.Id" class="btn btn-info btn-sm">👁️ Детайли</a>
                        <a asp-action="Edit" asp-route-id="@room.Id" class="btn btn-warning btn-sm">✏️ Редактирай</a>
                        <a asp-action="Delete" asp-route-id="@room.Id" class="btn btn-danger btn-sm">🗑️ Изтрий</a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="5" class="text-center">Няма стаи в базата данни.</td>
            </tr>
        }
    </tbody>
</table>