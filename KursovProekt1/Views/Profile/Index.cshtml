@model ControlPanel.Models.ApplicationUser

@{
    ViewData["Title"] = "Профил";
    var initials = (Model.FullName ?? Model.Email ?? "??").Substring(0, 2).ToUpper();
    var hasPhoto = !string.IsNullOrEmpty(Model.ProfilePicture);
}

<div class="cp-page-header">
    <div>
        <div class="cp-page-title">Моят профил</div>
        <div class="cp-page-subtitle">Управление на личната информация</div>
    </div>
</div>

<div class="cp-grid-2">

    @* Sol — profil kartı *@
    <div class="cp-card">
        <div class="cp-card-body" style="display:flex;flex-direction:column;align-items:center;text-align:center;padding:32px 20px">

            @* Profil resmi *@
            <div style="position:relative;margin-bottom:20px">
                @if (hasPhoto)
                {
                    <img src="/uploads/@Model.ProfilePicture" alt="Профил"
                         style="width:100px;height:100px;border-radius:50%;object-fit:cover;border:3px solid var(--border)" />
                }
                else
                {
                    <div style="width:100px;height:100px;border-radius:50%;background:#2563eb;display:flex;align-items:center;justify-content:center;font-size:32px;font-weight:700;color:#fff;border:3px solid var(--border)">
                        @initials
                    </div>
                }
            </div>

            <div style="font-size:18px;font-weight:700;margin-bottom:4px">@(Model.FullName ?? "—")</div>
            <div style="font-size:13px;color:var(--muted);margin-bottom:8px">@Model.Email</div>

            @* Rol badge *@
            @{
                var role = ViewBag.Role as string;
            }
            @if (role == "Admin")
            { <span class="cp-badge cp-badge-blue" style="margin-bottom:20px">Администратор</span> }
            else if (role == "Мениджър")
            { <span class="cp-badge cp-badge-amber" style="margin-bottom:20px">Мениджър</span> }
            else if (role == "Служител")
            { <span class="cp-badge cp-badge-gray" style="margin-bottom:20px">Служител</span> }
            else
            { <span class="cp-badge cp-badge-gray" style="margin-bottom:20px">Потребител</span> }

            @* Mini istatistikler *@
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;width:100%;margin-top:8px">
                <div style="background:var(--gray-bg);border-radius:var(--r);padding:12px;text-align:center">
                    <div style="font-size:22px;font-weight:700;color:var(--text)">@ViewBag.TotalRequests</div>
                    <div style="font-size:11px;color:var(--muted);margin-top:2px">Заявки</div>
                </div>
                <div style="background:var(--gray-bg);border-radius:var(--r);padding:12px;text-align:center">
                    <div style="font-size:22px;font-weight:700;color:#16a34a">@ViewBag.ApprovedRequests</div>
                    <div style="font-size:11px;color:var(--muted);margin-top:2px">Одобрени</div>
                </div>
            </div>

            <div style="font-size:12px;color:var(--hint);margin-top:16px">
                Регистриран на @Model.RegistrationDate.ToString("dd.MM.yyyy")
            </div>
        </div>
    </div>

    @* Sağ — düzenleme formu *@
    <div style="display:flex;flex-direction:column;gap:20px">

        <div class="cp-card">
            <div class="cp-card-header">
                <span class="cp-card-title">Редактирай информацията</span>
            </div>
            <div class="cp-card-body">
                <form asp-action="Update" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()

                    <div class="cp-form-group">
                        <label class="cp-form-label">Пълно име</label>
                        <input name="fullName" value="@Model.FullName" class="cp-form-control" placeholder="напр. Иван Петров" />
                    </div>

                    <div class="cp-form-group">
                        <label class="cp-form-label">Отдел</label>
                        <input name="department" value="@Model.Department" class="cp-form-control" placeholder="напр. IT отдел" />
                    </div>

                    <div class="cp-form-group">
                        <label class="cp-form-label">Профилна снимка</label>
                        <input name="profilePicture" type="file" accept="image/*" class="cp-form-control" />
                        <div class="cp-form-hint">JPG, PNG, GIF или WebP — максимум 2MB</div>
                    </div>

                    <div class="cp-form-actions">
                        <button type="submit" class="cp-btn cp-btn-primary">
                            <svg fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 0 1 0 1.414l-8 8a1 1 0 0 1-1.414 0l-4-4a1 1 0 0 1 1.414-1.414L8 12.586l7.293-7.293a1 1 0 0 1 1.414 0z" clip-rule="evenodd"/></svg>
                            Запази промените
                        </button>
                    </div>
                </form>
            </div>
        </div>

        @* Resim kaldırma — sadece resim varsa *@
        @if (hasPhoto)
        {
            <div class="cp-card">
                <div class="cp-card-header">
                    <span class="cp-card-title">Премахни снимката</span>
                </div>
                <div class="cp-card-body">
                    <p style="font-size:13px;color:var(--muted);margin-bottom:16px">
                        Профилната ви снимка ще бъде изтрита и ще се върне иницилата по подразбиране.
                    </p>
                    <form asp-action="RemovePicture" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="cp-btn cp-btn-danger">
                            <svg fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M9 2a1 1 0 0 0-.894.553L7.382 4H4a1 1 0 0 0 0 2v10a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2V6a1 1 0 1 0 0-2h-3.382l-.724-1.447A1 1 0 0 0 11 2H9zM7 8a1 1 0 0 1 2 0v6a1 1 0 1 1-2 0V8zm5-1a1 1 0 0 0-1 1v6a1 1 0 1 1 2 0V8a1 1 0 0 0-1-1z" clip-rule="evenodd"/></svg>
                            Премахни снимката
                        </button>
                    </form>
                </div>
            </div>
        }

    </div>
</div>
