@model IEnumerable<ControlPanel.Models.AccessRequest>

@{
    ViewData["Title"] = "Заявки";
}

<div class="cp-page-header">
    <div>
        <div class="cp-page-title">Заявки за достъп</div>
        <div class="cp-page-subtitle">
            @if (User.IsInRole("Admin"))
            {
                <text>Преглед и управление на всички заявки</text>
            }
            else
            {

                <text>Вашите заявки за достъп до стаи</text>
            }
        </div>
    </div>
    <a asp-action="Create" class="cp-btn cp-btn-primary">
        <svg fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 3a1 1 0 0 1 1 1v5h5a1 1 0 1 1 0 2h-5v5a1 1 0 1 1-2 0v-5H4a1 1 0 1 1 0-2h5V4a1 1 0 0 1 1-1z" clip-rule="evenodd" /></svg>
        Нова заявка
    </a>
</div>

<div class="cp-card">
    <div class="cp-card-body-flush">
        @if (!Model.Any())
        {
            <div class="cp-empty">
                <div class="cp-empty-icon">
                    <svg fill="currentColor" viewBox="0 0 20 20"><path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0 0 16 4H4a2 2 0 0 0-1.997 1.884z" /><path d="m18 8.118-8 4-8-4V14a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8.118z" /></svg>
                </div>
                <div class="cp-empty-title">Няма заявки</div>
                <div class="cp-empty-sub">Когато бъде подадена заявка за достъп, тя ще се появи тук.</div>
            </div>
        }
        else
        {
            <table class="cp-table">
                <thead>
                    <tr>
                        <th>Потребител</th>
                        <th>Стая</th>
                        <th>Причина</th>
                        <th>Дата</th>
                        <th>Статус</th>
                        @if (User.IsInRole("Admin"))
                        {
                            <th style="text-align:right;padding-right:20px">Действия</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var req in Model)
                    {
                        <tr>
                            <td>
                                <div style="display:flex;align-items:center;gap:8px">
                                    <div class="cp-avatar">@(req.User?.Email?.Substring(0, 2).ToUpper() ?? "??")</div>
                                    <span style="font-size:13px;font-weight:500">@(req.User?.Email ?? "—")</span>
                                </div>
                            </td>
                            <td style="font-weight:500;color:var(--blue-text)">@(req.Room?.RoomName ?? "—")</td>
                            <td style="color:var(--text-secondary);font-size:12px;max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">@req.Reason</td>
                            <td style="color:var(--text-secondary);font-size:12px">@req.RequestDate.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>
                                @if (req.Status == "Approved")
                                {
                                    <span class="cp-badge cp-badge-green"><span class="dot"></span> Одобрена</span>
                                }
                                else if (req.Status == "Denied")
                                {
                                    <span class="cp-badge cp-badge-red"><span class="dot"></span> Отказана</span>
                                }
                                else
                                {
                                    <span class="cp-badge cp-badge-amber"><span class="dot"></span> В изчакване</span>
                                }
                            </td>
                            @if (User.IsInRole("Admin"))
                            {
                                <td style="text-align:right;padding-right:16px">
                                    @if (req.Status == "Pending")
                                    {
                                        <div style="display:flex;gap:6px;justify-content:flex-end">
                                            <form method="post" asp-action="Approve" asp-route-id="@req.Id" style="display:inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="cp-btn-icon success" title="Одобри">
                                                    <svg fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 0 1 0 1.414l-8 8a1 1 0 0 1-1.414 0l-4-4a1 1 0 0 1 1.414-1.414L8 12.586l7.293-7.293a1 1 0 0 1 1.414 0z" clip-rule="evenodd" /></svg>
                                                </button>
                                            </form>
                                            <form method="post" asp-action="Deny" asp-route-id="@req.Id" style="display:inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="cp-btn-icon danger" title="Откажи">
                                                    <svg fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 0 1 1.414 0L10 8.586l4.293-4.293a1 1 0 1 1 1.414 1.414L11.414 10l4.293 4.293a1 1 0 0 1-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 0 1-1.414-1.414L8.586 10 4.293 5.707a1 1 0 0 1 0-1.414z" clip-rule="evenodd" /></svg>
                                                </button>
                                            </form>
                                        </div>
                                    }
                                    else
                                    {
                                        <span style="font-size:11px;color:var(--text-muted)">@req.AdminResponse</span>
                                    }
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
