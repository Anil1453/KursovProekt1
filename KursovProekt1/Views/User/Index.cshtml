@model IEnumerable<ControlPanel.Models.ApplicationUser>

@{
    ViewData["Title"] = "Потребители";
}

<div class="cp-page-header">
    <div>
        <div class="cp-page-title">Управление на потребители</div>
        <div class="cp-page-subtitle">Преглед и промяна на ролите на потребителите</div>
    </div>
    <span style="background:var(--gray-light);border:1px solid var(--border);padding:6px 12px;border-radius:var(--radius-md);font-size:12px;color:var(--text-secondary)">
        @Model.Count() потребителя
    </span>
</div>

<div class="cp-card">
    <div class="cp-card-body-flush">
        @if (Model.Any())
        {
            <table class="cp-table">
                <thead>
                    <tr>
                        <th>Потребител</th>
                        <th>Отдел</th>
                        <th>Регистрация</th>
                        <th>Статус</th>
                        <th>Текуща роля</th>
                        <th style="text-align:right;padding-right:20px">Промяна на роля</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        var currentRole = ViewBag.UserRoles[user.Id] as string ?? "Няма роля";
                        var isAdmin = currentRole == "Admin";

                        <tr>
                            <td>
                                <div style="display:flex;align-items:center;gap:10px">
                                    <div class="cp-avatar @(isAdmin ? "blue" : "")">
                                        @((user.FullName ?? user.Email ?? "??").Substring(0, 2).ToUpper())
                                    </div>
                                    <div>
                                        <div style="font-size:13px;font-weight:600">@(user.FullName ?? "—")</div>
                                        <div style="font-size:11px;color:var(--text-muted)">@user.Email</div>
                                    </div>
                                </div>
                            </td>
                            <td style="color:var(--text-secondary);font-size:12px">@(user.Department ?? "—")</td>
                            <td style="color:var(--text-secondary);font-size:12px">@user.RegistrationDate.ToString("dd.MM.yyyy")</td>
                            <td>
                                @if (user.IsActive)
                                {
                                    <span class="cp-badge cp-badge-green"><span class="dot"></span> Активен</span>
                                }
                                else
                                {
                                    <span class="cp-badge cp-badge-gray"><span class="dot"></span> Неактивен</span>
                                }
                            </td>
                            <td>
                                @if (currentRole == "Admin")
                                {
                                    <span class="cp-badge cp-badge-blue">Администратор</span>
                                }
                                else if (currentRole == "Мениджър")
                                {
                                    <span class="cp-badge cp-badge-amber">Мениджър</span>
                                }
                                else if (currentRole == "Служител")
                                {
                                    <span class="cp-badge cp-badge-gray">Служител</span>
                                }
                                else
                                {
                                    <span class="cp-badge cp-badge-gray">Потребител</span>
                                }
                            </td>
                            <td style="text-align:right;padding-right:16px">
                                @if (!isAdmin)
                                {
                                    <form method="post" asp-action="ChangeRole" style="display:flex;gap:6px;justify-content:flex-end;align-items:center">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="userId" value="@user.Id" />
                                        <select name="newRole" class="cp-form-control" style="width:auto;height:32px;padding:0 8px;font-size:12px">
                                            @if (currentRole == "Потребител")
                                            {
                                                <option value="Потребител" selected="selected">Потребител</option>
                                                <option value="Служител">Служител</option>
                                                <option value="Мениджър">Мениджър</option>
                                            }
                                            else if (currentRole == "Служител")
                                            {
                                                <option value="Потребител">Потребител</option>
                                                <option value="Служител" selected="selected">Служител</option>
                                                <option value="Мениджър">Мениджър</option>
                                            }
                                            else if (currentRole == "Мениджър")
                                            {
                                                <option value="Потребител">Потребител</option>
                                                <option value="Служител">Служител</option>
                                                <option value="Мениджър" selected="selected">Мениджър</option>
                                            }
                                            else
                                            {
                                                <option value="Потребител">Потребител</option>
                                                <option value="Служител">Служител</option>
                                                <option value="Мениджър">Мениджър</option>
                                            }
                                        </select>
                                        <button type="submit" class="cp-btn cp-btn-ghost" style="height:32px;padding:0 10px;font-size:12px">
                                            Запази
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <span style="font-size:11px;color:var(--text-muted);padding-right:4px">Защитена роля</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="cp-empty">
                <div class="cp-empty-icon">
                    <svg fill="currentColor" viewBox="0 0 20 20"><path d="M9 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0zM17 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 0 0-1.5-4.33A5 5 0 0 1 19 16v1h-6.07zM6 11a5 5 0 0 1 5 5v1H1v-1a5 5 0 0 1 5-5z"/></svg>
                </div>
                <div class="cp-empty-title">Няма потребители</div>
                <div class="cp-empty-sub">Все още няма регистрирани потребители.</div>
            </div>
        }
    </div>
</div>
